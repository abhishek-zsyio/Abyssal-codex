"use client";

import { ShieldAlert, RefreshCw } from "lucide-react";

export default function GlobalError({
  error,
  reset,
}: {
  error: Error & { digest?: string };
  reset: () => void;
}) {
  return (
    <html>
      <body style={{ margin: 0, padding: 0 }}>
        <div style={{ height: "100vh", backgroundColor: "#0a0a0a", color: "#ebdbb2", display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", fontFamily: "monospace", padding: "2rem", textAlign: "center" }}>
          <div style={{ maxWidth: "400px" }}>
            <div style={{ padding: "1rem", border: "2px solid #fb4934", marginBottom: "1rem", display: "inline-block" }}>
              <ShieldAlert size={48} color="#fb4934" />
            </div>
            
            <h1 style={{ fontSize: "1.5rem", fontWeight: "900", textTransform: "uppercase" }}>System_Kernel_Panic</h1>
            <p style={{ color: "#928374", fontSize: "0.75rem", textTransform: "uppercase", letterSpacing: "0.1em" }}>
              Critical exception in application runtime.
              <br />
              <span style={{ color: "#fb4934" }}>{error.message || "Hardware Failure"}</span>
            </p>

            <button
              onClick={() => reset()}
              style={{ marginTop: "2rem", display: "block", width: "100%", padding: "1rem", backgroundColor: "#fabd2f", color: "#0a0a0a", fontWeight: "bold", border: "none", cursor: "pointer", textTransform: "uppercase" }}
            >
              Reboot_System
            </button>
            
            <p style={{ fontSize: "8px", color: "#928374", marginTop: "3rem", opacity: 0.3 }}>
              DIGEST: {error.digest || "0x00000000"}
            </p>
          </div>
        </div>
      </body>
    </html>
  );
}
